# App
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# Supabase Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=documents

# Upstash Redis
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# CloudAMQP RabbitMQ
RABBITMQ_URL=amqps://[user]:[password]@[host].cloudamqp.com/[vhost]
RABBITMQ_QUEUE_NAME=document_processing
RABBITMQ_PREFETCH_COUNT=5

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_MAX_RETRIES=3

# Worker
WORKER_POOL_SIZE=5
WORKER_RETRY_MAX=3

# Rate Limiting
RATE_LIMIT_UPLOAD_RPS=2
RATE_LIMIT_GENERAL_RPS=20

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,txt

# Presigned URL
PRESIGNED_URL_EXPIRE_MINUTES=15
